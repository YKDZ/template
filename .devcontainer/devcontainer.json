{
  "name": "Template",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb",
        "serayuzgur.crates",
        "redhat.vscode-yaml",
        "fill-labs.dependi"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "file",
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.cargo.features": "all",
        "rust-analyzer.procMacro.enable": true,
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        },
        "[toml]": {
          "editor.defaultFormatter": "tamasfe.even-better-toml"
        }
      }
    }
  },
  "runArgs": [
    "--security-opt=seccomp=unconfined",
    "--security-opt=apparmor=unconfined",
    "--cap-add=SYS_ADMIN"
  ],
  "containerEnv": {
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",
    "RUST_BACKTRACE": "1"
  },
  "postCreateCommand": {
    "installNodeDependencies": "pnpm install",
    "prefetchRustDependencies": "cargo fetch"
  },
  "remoteUser": "root",
  "mounts": [
    "source=agen-cargo-registry,target=/usr/local/cargo/registry,type=volume",
    "source=agen-cargo-git,target=/usr/local/cargo/git,type=volume",
    "source=agen-target,target=${containerWorkspaceFolder}/target,type=volume"
  ]
}

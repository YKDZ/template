{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "paths": {
      "@ykdz/template-builtin-source": [
        "./packages/builtin-source/src/index.ts"
      ],
      "@ykdz/template-builtin-source/templates/*": [
        "./packages/builtin-source/templates/*.ts"
      ],
      "@ykdz/template-builtin-source/*": [
        "./packages/builtin-source/src/*.ts",
        "./packages/builtin-source/templates/*.ts",
        "./packages/builtin-source/templates/*"
      ],
      "@ykdz/template-checks/*": ["./packages/checks/src/*.ts"],
      "@ykdz/template-core/*": ["./packages/core/src/*.ts"],
      "@ykdz/template-shared": ["./packages/shared/src/index.ts"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "oxfmt.config.ts",
    "oxlint.config.ts",
    "packages/*/src/**/*.ts",
    "packages/builtin-source/templates/*/projection.ts",
    "packages/builtin-source/templates/projection-plans.ts",
    "packages/builtin-source/templates/registry.ts",
    "test/**/*.ts",
    "vitest.config.ts"
  ]
}

{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "oxfmt.config.ts",
    "oxlint.config.ts",
    "packages/*/src/**/*.ts",
    "packages/builtin-presets/src/*/behavior.test.ts",
    "packages/builtin-presets/templates/foundation/scripts/check-boundaries.ts",
    "packages/builtin-presets/templates/foundation/scripts/run-root-owned-task.ts",
    "test/**/*.ts",
    "vitest.config.ts"
  ]
}

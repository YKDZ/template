{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmitOnError": true,
    "outDir": "dist",
    "skipLibCheck": false,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "scripts/**/*.ts",
    "src/**/*.ts",
    "templates/shared/oxc/**/*.ts",
    "templates/registry.ts",
    "templates/projection-plans.ts",
    "templates/*/projection.ts",
    "test/**/*.ts"
  ]
}

{
  "$schema": "https://turborepo.com/schema.json",
  "boundaries": {
    "tags": {
      "template-checks": {
        "dependencies": {
          "allow": [
            "template-checks",
            "template-shared",
            "template-core",
            "template-builtin-presets"
          ]
        }
      },
      "template-builtin-presets": {
        "dependencies": {
          "allow": [
            "template-builtin-presets",
            "template-core",
            "template-shared",
            "template-checks"
          ]
        }
      },
      "template-cli": {
        "dependencies": {
          "allow": [
            "template-cli",
            "template-builtin-presets",
            "template-core",
            "template-shared",
            "template-checks"
          ]
        }
      },
      "template-core": {
        "dependencies": {
          "allow": [
            "template-core",
            "template-shared",
            "template-builtin-presets",
            "template-checks"
          ]
        }
      },
      "template-shared": {
        "dependencies": {
          "allow": [
            "template-shared",
            "template-core",
            "template-builtin-presets",
            "template-checks"
          ]
        }
      },
      "template-root": {
        "dependencies": {
          "allow": [
            "template-root",
            "template-checks",
            "template-cli",
            "template-builtin-presets",
            "template-core",
            "template-shared"
          ]
        }
      }
    }
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "check:fixtures": {
      "dependsOn": ["^build"],
      "outputs": [],
      "passThroughEnv": [
        "TEMPLATE_FIXTURE_CONCURRENCY",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_DIR",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_READ",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_WRITE"
      ]
    },
    "check:generated": {
      "dependsOn": ["^build"],
      "outputs": [],
      "passThroughEnv": [
        "TEMPLATE_FIXTURE_CONCURRENCY",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_DIR",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_READ",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_WRITE"
      ]
    },
    "check:focused": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "check:deployment": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "check:templates": {
      "dependsOn": ["^build"],
      "outputs": [],
      "passThroughEnv": ["CARGO_HOME", "RUSTUP_HOME", "RUSTUP_TOOLCHAIN"]
    },
    "check:templates:boundary": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "check:templates:github-yaml": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "check:toolchain:online": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "format:write": {
      "dependsOn": ["lint:fix"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "boundaries": {
      "cache": false,
      "outputs": []
    },
    "//#boundaries": {
      "cache": false,
      "outputs": []
    },
    "//#format:check": {
      "outputs": []
    },
    "//#format:write": {
      "dependsOn": ["lint:fix"],
      "cache": false
    },
    "//#lint": {
      "outputs": []
    },
    "//#lint:fix": {
      "cache": false
    },
    "//#typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": []
    },
    "//#test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}

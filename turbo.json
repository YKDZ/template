{
  "$schema": "https://turborepo.com/schema.json",
  "boundaries": {
    "tags": {
      "template-checks": {
        "dependencies": {
          "allow": [
            "template-core",
            "template-preset-source",
            "template-shared"
          ]
        }
      },
      "template-cli": {
        "dependencies": {
          "allow": [
            "template-checks",
            "template-core",
            "template-preset-source",
            "template-shared"
          ]
        }
      },
      "template-core": {
        "dependencies": {
          "allow": [
            "template-checks",
            "template-cli",
            "template-preset-source",
            "template-shared"
          ]
        }
      },
      "template-preset-source": {
        "dependencies": {
          "allow": [
            "template-checks",
            "template-cli",
            "template-core",
            "template-preset-source",
            "template-shared"
          ]
        }
      },
      "template-shared": {
        "dependencies": {
          "allow": [
            "template-checks",
            "template-cli",
            "template-core",
            "template-preset-source"
          ]
        }
      }
    }
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "check:fixtures": {
      "dependsOn": ["transit"],
      "outputs": [],
      "passThroughEnv": [
        "TEMPLATE_FIXTURE_CONCURRENCY",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_DIR",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_READ",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_WRITE"
      ]
    },
    "check:generated": {
      "dependsOn": ["transit"],
      "outputs": [],
      "passThroughEnv": [
        "TEMPLATE_FIXTURE_CONCURRENCY",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_DIR",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_READ",
        "TEMPLATE_FIXTURE_REPLAY_CACHE_WRITE"
      ]
    },
    "check:templates": {
      "outputs": [],
      "passThroughEnv": ["CARGO_HOME", "RUSTUP_HOME", "RUSTUP_TOOLCHAIN"]
    },
    "check:templates:boundary": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "check:templates:github-yaml": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "check:templates:shared-oxc": {
      "outputs": []
    },
    "check:templates:static-source": {
      "outputs": [],
      "passThroughEnv": ["CARGO_HOME", "RUSTUP_HOME", "RUSTUP_TOOLCHAIN"]
    },
    "check:toolchain:online": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "format:write": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "//#format:check:root": {
      "outputs": []
    },
    "//#format:write:root": {
      "cache": false
    },
    "//#lint:root": {
      "outputs": []
    },
    "//#lint:fix:root": {
      "cache": false
    },
    "//#test": {
      "outputs": []
    },
    "//#typecheck:root": {
      "outputs": []
    }
  }
}

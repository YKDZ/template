        "pinia",
        "tailwindcss",
        "tsc-alias",
        "tsx",
        "turbo",
        "typescript",
        "vite",
        "vitest",
        "vue",
        "vue-tsc"
      ],
      "source": {
        "roots": [
          "vue-hono-app/.github",

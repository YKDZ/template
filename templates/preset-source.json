{
  "schemaVersion": 1,
  "name": "built-in",
  "sharedResources": [
    {
      "id": "shared-devcontainer",
      "path": "shared/devcontainer"
    },
    {
      "id": "shared-editor-customization",
      "path": "shared/editor-customization/capabilities.json"
    },
    {
      "id": "shared-oxc-node",
      "path": "shared/oxc/node"
    },
    {
      "id": "shared-oxc-format",
      "path": "shared/oxc/oxfmt.config.ts"
    },
    {
      "id": "shared-oxc-vue",
      "path": "shared/oxc/vue"
    }
  ],
  "presets": [
    {
      "name": "ts-lib",
      "title": "TypeScript library",
      "description": "Strict TypeScript package with pnpm catalog tooling.",
      "generation": "supported",
      "supportedPackageManagers": ["pnpm"],
      "supportedProjectKinds": ["multi-package"],
      "packageAdditionSupport": "supported",
      "features": [
        "pnpm-catalog",
        "oxc-format-lint",
        "strict-typescript",
        "root-check",
        "fix-command",
        "devcontainer",
        "github-actions",
        "dependabot"
      ],
      "dependencyCatalog": [
        "@types/node",
        "oxfmt",
        "oxlint",
        "turbo",
        "typescript",
        "valibot"
      ],
      "projection": {
        "capabilities": [
          {
            "kind": "workspace-library-package",
            "workspacePackageGlob": "packages/*",
            "packageRole": "shared-library",
            "packageSourcePreset": "ts-lib",
            "sourceFiles": ["src/index.ts", "src/name-schema.ts"]
          },
          { "kind": "strict-typescript-root" },
          { "kind": "oxc-format-lint" },
          { "kind": "node-pnpm-devcontainer" },
          { "kind": "github-maintenance" }
        ]
      },
      "source": {
        "roots": ["ts-lib/.github", "ts-lib/src"],
        "sharedResources": [
          "shared-devcontainer",
          "shared-editor-customization",
          "shared-oxc-node",
          "shared-oxc-format"
        ]
      }
    },
    {
      "name": "hono-api",
      "title": "Hono API",
      "description": "Hono Node API workspace with strict TypeScript tooling.",
      "generation": "supported",
      "supportedPackageManagers": ["pnpm"],
      "supportedProjectKinds": ["multi-package"],
      "packageAdditionSupport": "supported",
      "features": [
        "pnpm-catalog",
        "oxc-format-lint",
        "strict-typescript",
        "root-check",
        "fix-command",
        "devcontainer",
        "github-actions",
        "dependabot"
      ],
      "dependencyCatalog": [
        "@hono/node-server",
        "@types/node",
        "hono",
        "oxfmt",
        "oxlint",
        "tsc-alias",
        "turbo",
        "typescript",
        "vitest"
      ],
      "source": {
        "roots": ["hono-api/.github", "hono-api/src", "hono-api/test"],
        "files": ["hono-api/vitest.config.ts"],
        "sharedResources": [
          "shared-devcontainer",
          "shared-editor-customization",
          "shared-oxc-node",
          "shared-oxc-format"
        ]
      }
    },
    {
      "name": "vue-app",
      "title": "Vue app",
      "description": "Vue app workspace with Vite, Tailwind, Pinia, and test tooling.",
      "generation": "supported",
      "supportedPackageManagers": ["pnpm"],
      "supportedProjectKinds": ["multi-package"],
      "packageAdditionSupport": "supported",
      "features": [
        "pnpm-catalog",
        "oxc-format-lint",
        "strict-typescript",
        "root-check",
        "fix-command",
        "devcontainer",
        "github-actions",
        "dependabot"
      ],
      "dependencyCatalog": [
        "@playwright/test",
        "@tailwindcss/vite",
        "@types/node",
        "@types/web-bluetooth",
        "@vitejs/plugin-vue",
        "@vue/tsconfig",
        "@vueuse/core",
        "oxfmt",
        "oxlint",
        "pinia",
        "tailwindcss",
        "turbo",
        "typescript",
        "vite",
        "vitest",
        "vue",
        "vue-tsc"
      ],
      "source": {
        "roots": ["vue-app/.github", "vue-app/src", "vue-app/test"],
        "files": [
          "vue-app/env.d.ts",
          "vue-app/index.html",
          "vue-app/playwright.config.ts",
          "vue-app/vite.config.ts",
          "vue-app/vitest.config.ts"
        ],
        "sharedResources": [
          "shared-devcontainer",
          "shared-editor-customization",
          "shared-oxc-format",
          "shared-oxc-vue"
        ]
      }
    },
    {
      "name": "vue-hono-app",
      "title": "Vue Hono app",

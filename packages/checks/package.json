{
  "name": "@ykdz/template-checks",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check:fixtures": "node src/check-generated-registry.ts package-addition-matrix",
    "check:generated": "node src/check-generated-registry.ts init",
    "check:focused": "node src/check-generated-registry.ts focused",
    "check:deployment": "node src/check-generated-registry.ts deployment",
    "check:templates": "node src/check-legacy-architecture-removal.ts --packed",
    "check:templates:github-yaml": "node src/check-builtin-preset-github-yaml.ts",
    "check:toolchain:online": "node src/check-online-toolchain-resolution-contract.ts",
    "update:toolchain": "node src/update-toolchain-baseline.ts",
    "format:check": "oxfmt --list-different --config ../../oxfmt.config.ts .",
    "format:write": "oxfmt --write --config ../../oxfmt.config.ts .",
    "lint": "oxlint --quiet --format=unix --config ../../oxlint.config.ts --ignore-pattern dist .",
    "lint:fix": "oxlint --format=unix --config ../../oxlint.config.ts --ignore-pattern dist . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@ykdz/template-builtin-presets": "workspace:*",
    "@ykdz/template-core": "workspace:*",
    "execa": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:",
    "typescript-7": "catalog:"
  },
  "turbo": {
    "tags": [
      "template-checks"
    ]
  }
}

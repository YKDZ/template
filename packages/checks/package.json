{
  "name": "@ykdz/template-checks",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "source": {
        "types": "./src/*.ts",
        "default": "./src/*.ts"
      },
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check:fixtures": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--conditions=source\" tsx --tsconfig ../../tsconfig.json src/check-fixtures.ts",
    "check:generated": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--conditions=source\" tsx --tsconfig ../../tsconfig.json src/check-generated.ts",
    "check:templates": "pnpm run check:templates:github-yaml && pnpm run check:templates:boundary",
    "check:templates:boundary": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--conditions=source\" tsx --tsconfig ../../tsconfig.json src/check-template-boundary.ts",
    "check:templates:github-yaml": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--conditions=source\" tsx --tsconfig ../../tsconfig.json src/check-template-github-yaml.ts",
    "check:toolchain:online": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--conditions=source\" tsx --tsconfig ../../tsconfig.json src/check-online-toolchain-resolution-contract.ts",
    "format:check": "oxfmt --list-different --config ../../oxfmt.config.ts .",
    "format:write": "oxfmt --write --config ../../oxfmt.config.ts .",
    "lint": "oxlint --quiet --format=unix --config ../../oxlint.config.ts --ignore-pattern dist .",
    "lint:fix": "oxlint --format=unix --config ../../oxlint.config.ts --ignore-pattern dist . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@ykdz/template-builtin-source": "workspace:*",
    "@ykdz/template-core": "workspace:*",
    "@ykdz/template-shared": "workspace:*",
    "execa": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsx": "catalog:"
  }
}

          "vike-app/web/vitest.config.ts"
        ],
        "sharedResources": [
          "shared-devcontainer",
          "shared-editor-customization",
          "shared-oxc-format",
          "shared-oxc-root-tsconfig",
          "shared-oxc-vue",
          "shared-typescript",
          "shared-toolchain-maintenance"
        ]
      }
    },

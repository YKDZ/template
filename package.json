{
  "name": "@ykdz/template-repository",
  "private": true,
  "description": "Repository workspace for the YKDZ template generator.",
  "type": "module",
  "scripts": {
    "build": "turbo run build --filter=!// --output-logs=errors-only --log-order=grouped",
    "check": "turbo run boundaries format:check lint typecheck build test test:e2e check:generated check:templates check:templates:boundary check:templates:github-yaml --continue=dependencies-successful --output-logs=errors-only --log-order=grouped --log-prefix=task",
    "check:fixtures": "turbo run check:fixtures --output-logs=errors-only --log-order=grouped",
    "check:generated": "turbo run check:generated --output-logs=errors-only --log-order=grouped",
    "check:deployment": "turbo run check:deployment --output-logs=errors-only --log-order=grouped",
    "check:templates": "turbo run check:templates --output-logs=errors-only --log-order=grouped",
    "check:templates:boundary": "turbo run check:templates:boundary --output-logs=errors-only --log-order=grouped",
    "check:templates:github-yaml": "turbo run check:templates:github-yaml --output-logs=errors-only --log-order=grouped",
    "check:toolchain:online": "turbo run check:toolchain:online --output-logs=errors-only --log-order=grouped",
    "update:toolchain": "pnpm --filter @ykdz/template-checks update:toolchain",
    "resolve:toolchain:update": "node packages/checks/src/update-toolchain-baseline.ts --print-workflow-outputs",
    "fix": "turbo run lint:fix format:write --continue=dependencies-successful --output-logs=full --log-order=grouped --log-prefix=task",
    "boundaries": "node scripts/check-boundaries.ts",
    "format:check": "oxfmt --list-different --config oxfmt.config.ts $(git ls-files -- ':!packages/**')",
    "format:write": "oxfmt --write --config oxfmt.config.ts $(git ls-files -- ':!packages/**')",
    "lint": "oxlint --quiet --format=unix --config oxlint.config.ts oxlint.config.ts oxfmt.config.ts vitest.config.ts scripts test",
    "lint:fix": "oxlint --format=unix --config oxlint.config.ts oxlint.config.ts oxfmt.config.ts vitest.config.ts scripts test --fix",
    "test": "vitest run test --reporter=agent --silent=passed-only",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@ykdz/template-builtin-presets": "workspace:*",
    "@ykdz/template-checks": "workspace:*",
    "@ykdz/template-core": "workspace:*",
    "@ykdz/template-shared": "workspace:*",
    "execa": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-7": "catalog:",
    "valibot": "catalog:",
    "vitest": "catalog:",
    "yaml": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.11.0",
  "turbo": {
    "tags": [
      "template-root"
    ]
  }
}

{
  "name": "@ykdz/template",
  "version": "0.0.3",
  "private": false,
  "description": "Project template generator for YKDZ starter projects.",
  "keywords": [
    "cli",
    "project-template",
    "starter"
  ],
  "homepage": "https://github.com/YKDZ/template#readme",
  "bugs": {
    "url": "https://github.com/YKDZ/template/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YKDZ/template.git"
  },
  "bin": {
    "template": "dist/src/cli.js"
  },
  "files": [
    "dist",
    "pnpm-workspace.yaml",
    "templates",
    "!templates/shared/oxc/tsconfig.json",
    "!templates/**/node_modules"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "check": "pnpm run check:format && pnpm run typecheck && pnpm run test && pnpm run check:templates && pnpm run check:fixtures",
    "check:format": "oxfmt --check --config templates/shared/oxc/oxfmt.config.ts --ignore-path .oxfmtignore .",
    "check:fixtures": "tsx scripts/check-fixtures.ts",
    "check:templates": "pnpm run check:templates:shared-oxc && pnpm run check:templates:github-yaml && pnpm run check:templates:static-source",
    "check:toolchain:online": "tsx scripts/check-online-toolchain-resolution-contract.ts",
    "check:templates:github-yaml": "tsx scripts/check-template-github-yaml.ts",
    "check:templates:shared-oxc": "pnpm run check:templates:shared-oxc:format && pnpm run check:templates:shared-oxc:lint && pnpm run check:templates:shared-oxc:typecheck",
    "check:templates:shared-oxc:format": "oxfmt --check templates/shared/oxc",
    "check:templates:shared-oxc:lint": "oxlint templates/shared/oxc --deny-warnings",
    "check:templates:shared-oxc:typecheck": "tsc -p templates/shared/oxc/tsconfig.json --noEmit",
    "check:templates:static-source": "rustfmt --check templates/rust-bin/src/main.rs",
    "fix": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "typescript": "^6.0.3",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "execa": "^9.6.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.0.0"
}
